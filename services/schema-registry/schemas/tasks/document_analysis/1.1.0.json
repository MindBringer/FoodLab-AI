{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "tasks/document_analysis/1.1.0",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "document_type": {
      "type": "string"
    },
    "sample_type": {
      "type": [
        "string",
        "null"
      ]
    },
    "product_name": {
      "type": [
        "string",
        "null"
      ]
    },
    "matrix": {
      "type": [
        "string",
        "null"
      ]
    },
    "assessment": {
      "type": [
        "string",
        "null"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "parameter": {
            "type": "string"
          },
          "value": {
            "type": [
              "number",
              "null"
            ]
          },
          "unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "limit_value": {
            "type": [
              "number",
              "null"
            ]
          },
          "limit_unit": {
            "type": [
              "string",
              "null"
            ]
          },
          "status": {
            "type": [
              "string",
              "null"
            ],
            "enum": [
              "ok",
              "above_limit",
              "below_limit",
              "unknown",
              null
            ]
          }
        },
        "required": [
          "parameter"
        ]
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "document_type",
    "findings",
    "warnings"
  ]
}