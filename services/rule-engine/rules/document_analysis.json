{
  "rule_set": "document_analysis_v2",
  "rules": [
    {
      "rule_id": "lead_max",
      "field": "findings[]",
      "where": {
        "parameter_equals": "Blei"
      },
      "compare_field": "value",
      "max": 0.1,
      "severity": "warning",
      "message": "Blei-Grenzwert überschritten"
    },
    {
      "rule_id": "cadmium_max",
      "field": "findings[]",
      "where": {
        "parameter_equals": "Cadmium"
      },
      "compare_field": "value",
      "max": 0.1,
      "severity": "warning",
      "message": "Cadmium-Grenzwert überschritten"
    },
    {
      "rule_id": "contract_keyword",
      "field": "document_type",
      "equals": "contract",
      "severity": "info",
      "message": "Vertrag erkannt"
    }
  ]
}